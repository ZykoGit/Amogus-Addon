{
	"format_version": "1.20.0",
	"minecraft:entity": {
		"description": {
			"identifier": "gus:amogus",
			"is_spawnable": false,
			"is_summonable": true,
			"is_experimental": false
		},
		"component_groups": {
			"gus:amogus_baby": {
				"minecraft:is_baby": {},
				"minecraft:scale": {
					"value": 0.5
				},
				"minecraft:ageable": {
					"duration": 1200,
					"feed_items": ["cookie"],
					"grow_up": {
						"event": "minecraft:ageable_grow_up",
						"target": "self"
					}
				},
				"minecraft:behavior.follow_parent": {
					"priority": 5,
					"speed_multiplier": 1.1
				}
			},
			"gus:amogus_adult": {
				"minecraft:experience_reward": {
					"on_bred": "Math.Random(1,7)",
					"on_death": "query.last_hit_by_player ? Math.Random(1,3) : 0"
				},
				"minecraft:loot": {
					"table": "loot_tables/entities/amogus.json"
				},
				"minecraft:breedable": {
					"require_tame": false,
					"breeds_with": {
						"mate_type": "gus:amogus",
						"baby_type": "gus:amogus",
						"breed_event": {
							"event": "minecraft:entity_born",
							"target": "baby"
						}
					},
					"breed_items": ["cookie"]
				},
				"minecraft:behavior.breed": {
					"priority": 3,
					"speed_multiplier": 1
				}
			}
		},
		"components": {
			"minecraft:type_family": {
				"family": ["mob"]
			},
			"minecraft:breathable": {
				"total_supply": 30,
				"suffocate_time": 0
			},
			"minecraft:collision_box": {
				"width": 0.6,
				"height": 0.8
			},
			"minecraft:nameable": {},
			"minecraft:health": {
				"value": 4,
				"max": 4
			},
			"minecraft:hurt_on_condition": {
				"damage_conditions": [
					{
						"filters": {
							"test": "in_lava",
							"subject": "self",
							"operator": "==",
							"value": true
						},
						"cause": "lava",
						"damage_per_tick": 4
					}
				]
			},
			"minecraft:movement": {
				"value": 0.25
			},
			"minecraft:damage_sensor": {
